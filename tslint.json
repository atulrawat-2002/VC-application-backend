{
    "extends": "tslint:recommended",
    "defaultSeverity": "error",
    "rules": {
        "object-literal-sort-keys": false,
        "no-console": {
            "severity": "warning",
            "options": ["debug", "info", "log", "trace"]
        },
        "max-line-length": [true, 100],
        "semicolon": {
            "options": [
                "always"
            ]
        }
    },
    "jsRules": {
        
    }
}